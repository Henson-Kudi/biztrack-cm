# Mobile App Environment Variables
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ─── API ─────────────────────────────────────────────────────────────────────
# Full base URL of the BizTrack API including version prefix.
# For local development, use your machine's LAN IP — NOT localhost.
# (On a physical device or emulator, localhost resolves to the device itself.)
#
# Find your LAN IP:
#   Windows: ipconfig  → look for IPv4 Address (e.g. 192.168.1.100)
#   macOS/Linux: ifconfig | grep "inet " | grep -v 127.0.0.1
#
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api/v1
EXPO_PUBLIC_API_URL=http://<YOUR_LAN_IP>:3000/api/v1
