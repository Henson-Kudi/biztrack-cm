{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@biztrack/types": [
        "../../packages/types/src"
      ],
      "@biztrack/utils": [
        "../../packages/utils/src"
      ],
      "@biztrack/validators": [
        "../../packages/validators/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
