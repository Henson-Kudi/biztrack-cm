{
  "name": "@biztrack/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint . --max-warnings 0",
    "test": "jest -c jest.config.ts --runInBand",
    "test:coverage": "jest -c jest.config.ts --runInBand --coverage",
    "type-check": "tsc --noEmit",
    "typeorm": "node -r tsconfig-paths/register ./node_modules/typeorm/cli-ts-node-commonjs.js",
    "migration:create": "pnpm run typeorm -- migration:create",
    "migration:generate": "node scripts/migration-generate.js",
    "migration:run": "node -r tsconfig-paths/register ./node_modules/typeorm/cli-ts-node-commonjs.js migration:run -d src/database/data-source.ts",
    "migration:show": "node -r tsconfig-paths/register ./node_modules/typeorm/cli-ts-node-commonjs.js migration:show -d src/database/data-source.ts",
    "migration:revert": "node -r tsconfig-paths/register ./node_modules/typeorm/cli-ts-node-commonjs.js migration:revert -d src/database/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register database/seeds/seed.ts",
    "seed:plans": "ts-node -r tsconfig-paths/register src/database/seeds/seed-plan-configs.ts"
  },
  "dependencies": {
    "@biztrack/logger": "workspace:*",
    "@biztrack/types": "workspace:*",
    "@biztrack/utils": "workspace:*",
    "@biztrack/validators": "workspace:*",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.6",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "nestjs-i18n": "^10.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "4.8.3",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biztrack/eslint-config": "workspace:*",
    "@biztrack/typescript-config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.32.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
