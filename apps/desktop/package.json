{
  "name": "@biztrack/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "BizTrack CM desktop point of sale application",
  "author": "BizTrack CM",
  "main": "dist/electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "node scripts/dev-full.js",
    "dev:renderer": "set NEXT_DISABLE_SWC=1 && next dev -p 3004",
    "dev:full": "node scripts/dev-full.js",
    "dev:full:compat": "node scripts/dev-full.js",
    "build": "next build && node scripts/copy-renderer-output.js && tsc -p tsconfig.electron.json",
    "start": "node scripts/start-prod.js",
    "prepare:icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "prepare:installer": "powershell -ExecutionPolicy Bypass -File scripts/prepare-installer.ps1",
    "build:dist": "pnpm run build && pnpm run prepare:installer && electron-builder --win nsis",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@biztrack/http-client": "workspace:*",
    "@biztrack/theme": "workspace:*",
    "@biztrack/types": "workspace:*",
    "@biztrack/ui": "workspace:*",
    "@biztrack/utils": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.3.9",
    "next": "^15.1.3",
    "next-intl": "latest",
    "next-themes": "^0.3.0",
    "pdf-to-printer": "^5.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "socket.io-client": "4.8.3",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biztrack/eslint-config": "workspace:*",
    "@biztrack/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.5",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.32.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
