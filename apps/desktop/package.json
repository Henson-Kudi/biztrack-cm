{
  "name": "@biztrack/desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "set NEXT_DISABLE_SWC=1 && next dev -p 3000",
    "dev:full": "node scripts/dev-full.js",
    "dev:full:compat": "node scripts/dev-full.js",
    "build": "next build && next export -o dist/renderer && tsc -p tsconfig.electron.json",
    "build:dist": "npm run build && electron-builder",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@biztrack/theme": "workspace:^",
    "@biztrack/types": "workspace:*",
    "@biztrack/ui": "workspace:*",
    "@biztrack/utils": "workspace:*",
    "autoprefixer": "^10.4.27",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "next": "^15.1.3",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biztrack/eslint-config": "workspace:*",
    "@biztrack/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.32.0",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
