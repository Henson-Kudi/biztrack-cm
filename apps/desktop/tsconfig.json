{
  "extends": "@biztrack/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@biztrack/types": [
        "../../packages/types/src"
      ],
      "@biztrack/utils": [
        "../../packages/utils/src"
      ],
      "@biztrack/ui": [
        "../../packages/ui/src"
      ]
    }
  },
  "include": [
    "dist/next/types/**/*.ts",
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
